[
  {
    "id": "threshold_family_low_runway_lock",
    "name": "门槛事件 x 家庭角色 x 低资产缓冲",
    "if": {
      "symbolic_all": ["threshold_event_as_identity_gate"],
      "symbolic_any": ["family_title_as_role_lock", "institution_name_as_evaluation_shadow"],
      "world_scores": {
        "financial_runway_lte": 3
      }
    },
    "branch_effects": {
      "inertia": 1.4,
      "intervention": -0.2
    },
    "interpretation": "当身份门槛没有跨过，同时家庭角色和低资产缓冲存在，人的行动会更容易被“先证明自己正常”锁住。"
  },
  {
    "id": "self_archive_public_artifact_observer_turn",
    "name": "自我档案 x 公开作品 x 观察者",
    "if": {
      "symbolic_all": ["self_archive_as_identity_system"],
      "symbolic_any": ["public_artifact_as_identity_proof", "nickname_or_online_handle_identity"],
      "inner_agents_any": ["observer", "prover"]
    },
    "branch_effects": {
      "intervention": 1.8
    },
    "interpretation": "当自我整理系统变成公开作品，观察者不再只负责分析，证明者也不再只靠幻想证明，而会进入现实反馈。"
  },
  {
    "id": "lost_rhythm_body_inertia_loop",
    "name": "失去节律 x 身体事件 x 控制者",
    "if": {
      "symbolic_all": ["lost_rhythm_as_original_self_myth", "body_illness_as_lost_rhythm_symbol"],
      "inner_agents_any": ["controller", "observer"]
    },
    "branch_effects": {
      "inertia": 0.9,
      "intervention": 0.4
    },
    "interpretation": "旧节律记忆会同时带来恢复动力和自我审判：如果只怀念过去，默认线增强；如果重建小节律，干预线也会打开。"
  },
  {
    "id": "betrayal_pleaser_silence_lock",
    "name": "欺骗伤口 x 讨好者 x 沉默",
    "if": {
      "symbolic_all": ["fraud_or_betrayal_as_trust_injury"],
      "inner_agents_any": ["pleaser", "controller"]
    },
    "branch_effects": {
      "inertia": 0.8,
      "rupture": 0.5
    },
    "interpretation": "当信任伤口遇到讨好和控制策略，人更可能把问题藏到太晚，最终要么拖住，要么突然断裂。"
  },
  {
    "id": "pet_low_support_rupture_buffer",
    "name": "宠物 x 低支持网络：断裂缓冲",
    "if": {
      "symbolic_all": ["pet_as_daily_anchor"],
      "world_scores": {
        "support_capacity_lte": 6
      }
    },
    "branch_effects": {
      "rupture": -0.7,
      "inertia": 0.2
    },
    "interpretation": "当人的社会支持不强，宠物会成为具体日常责任，降低彻底切断生活结构的概率。"
  },
  {
    "id": "money_shame_prover_visibility_pressure",
    "name": "金额羞耻 x 证明者 x 可见度压力",
    "if": {
      "symbolic_all": ["money_amount_as_shame_marker"],
      "inner_agents_any": ["prover"],
      "external_agents_any": ["labor_market", "city_pressure"]
    },
    "branch_effects": {
      "intervention": 0.7,
      "rupture": 0.4
    },
    "interpretation": "金钱羞耻会推动人想快速证明自己，但如果没有节律和缓冲，也会提高耗竭式行动的风险。"
  },
  {
    "id": "place_split_online_identity_new_field",
    "name": "地点分裂 x 线上身份：新场域入口",
    "if": {
      "symbolic_all": ["place_split_identity"],
      "symbolic_any": ["nickname_or_online_handle_identity", "public_artifact_as_identity_proof", "self_archive_as_identity_system"]
    },
    "branch_effects": {
      "intervention": 1
    },
    "interpretation": "当现实地点悬置时，线上身份或公开作品可以成为新的场域入口，让人不必先等现实身份完全稳定。"
  },
  {
    "id": "unfinished_object_attention_debt",
    "name": "未完成物 x 注意力债务",
    "if": {
      "symbolic_all": ["unfinished_object_as_open_loop"],
      "world_scores": {
        "energy_risk_gte": 4
      }
    },
    "branch_effects": {
      "inertia": 0.8,
      "rupture": 0.2
    },
    "interpretation": "未完成物越多，注意力债务越重，行动越容易被旧项目幽灵拖住。"
  },
  {
    "id": "date_private_clock_public_commitment",
    "name": "私人时钟 x 公开承诺",
    "if": {
      "symbolic_all": ["repeated_number_or_date_as_private_clock"],
      "symbolic_any": ["public_artifact_as_identity_proof"]
    },
    "branch_effects": {
      "intervention": 0.8
    },
    "interpretation": "日期如果只在心里倒计时会制造焦虑；如果变成公开承诺，会转成行动触发器。"
  },
  {
    "id": "institution_shadow_public_artifact_rewrite",
    "name": "机构阴影 x 公开作品：评价系统改写",
    "if": {
      "symbolic_all": ["institution_name_as_evaluation_shadow"],
      "symbolic_any": ["public_artifact_as_identity_proof", "self_archive_as_identity_system"]
    },
    "branch_effects": {
      "intervention": 0.9,
      "inertia": -0.2
    },
    "interpretation": "当学校或公司名带来羞耻，公开作品可以逐渐改写评价系统，让人不再只被旧机构定义。"
  }
]
